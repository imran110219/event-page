---
import { siteConfig } from '../data/site';

interface Props {
  totalUpcoming: number;
  nextEventDate: string;
  totalCategories: number;
}

const { totalUpcoming, nextEventDate, totalCategories } = Astro.props;
---

<section class="relative overflow-hidden pt-36 pb-20 md:pt-44 md:pb-24">
  <div class="absolute inset-0 -z-10 bg-gradient-to-br from-brand-900 via-brand-700 to-surface-900"></div>
  <div class="absolute -top-20 left-10 h-64 w-64 rounded-full bg-brand-300/25 blur-3xl animate-pulseGlow"></div>
  <div class="absolute top-24 right-0 h-72 w-72 rounded-full bg-accent-500/25 blur-3xl animate-floaty"></div>
  <div class="absolute bottom-0 left-1/3 h-56 w-56 rounded-full bg-white/10 blur-3xl"></div>

  <div class="section-shell">
    <div class="max-w-4xl" data-animate="reveal">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-100">Trusted Event Platform</p>
      <h1 class="mt-4 font-display text-4xl font-semibold leading-tight tracking-tight text-white md:text-6xl">
        {siteConfig.name}
      </h1>
      <p class="mt-6 max-w-2xl text-base leading-relaxed text-white/85 md:text-lg">{siteConfig.tagline}</p>

      <div class="mt-8 flex flex-wrap items-center gap-4">
        <a href="#events" class="rounded-full bg-white px-6 py-3 text-sm font-semibold text-brand-700 shadow-card transition hover:-translate-y-0.5 hover:bg-brand-50">View Upcoming Events</a>
      </div>
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-3" data-animate="reveal">
      <article class="glass-panel rounded-2xl p-5">
        <p class="text-xs uppercase tracking-[0.15em] text-surface-600">Upcoming events</p>
        <p class="mt-2 font-display text-3xl font-semibold text-surface-900">{totalUpcoming}</p>
      </article>
      <article class="glass-panel rounded-2xl p-5">
        <p class="text-xs uppercase tracking-[0.15em] text-surface-600">Next event</p>
        <p class="mt-2 font-display text-xl font-semibold text-surface-900">{nextEventDate}</p>
      </article>
      <article class="glass-panel rounded-2xl p-5">
        <p class="text-xs uppercase tracking-[0.15em] text-surface-600">Categories</p>
        <p class="mt-2 font-display text-3xl font-semibold text-surface-900">{totalCategories}</p>
      </article>
    </div>
  </div>
</section>
