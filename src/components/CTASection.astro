---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<section id="contact" class="section-shell py-20">
  <div class="relative overflow-hidden rounded-3xl border border-brand-100 bg-gradient-to-br from-brand-700 via-brand-800 to-surface-900 p-8 text-white shadow-card md:p-12" data-animate="reveal">
    <div class="absolute -top-20 right-0 h-64 w-64 rounded-full bg-white/10 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 h-56 w-56 rounded-full bg-accent-500/20 blur-3xl"></div>

    <div class="relative max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-100">Get Involved</p>
      <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight md:text-4xl">{title}</h2>
      <p class="mt-4 max-w-2xl text-base text-white/85">{description}</p>

      <div class="mt-8 flex flex-wrap gap-4">
        <a href="mailto:hello@summitorganization.org" class="rounded-full bg-white px-6 py-3 text-sm font-semibold text-brand-700 transition hover:bg-brand-50">Contact Our Team</a>
        <a href="#events" class="rounded-full border border-white/40 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10">Explore Events</a>
      </div>
    </div>
  </div>
</section>
