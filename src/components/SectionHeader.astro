---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  centered?: boolean;
}

const { eyebrow, title, description, centered = false } = Astro.props;
---

<header class:list={[centered ? 'mx-auto max-w-3xl text-center' : 'max-w-3xl']} data-animate="reveal">
  {eyebrow && <p class="mb-2 text-xs font-semibold uppercase tracking-[0.18em] text-brand-700">{eyebrow}</p>}
  <h2 class="font-display text-3xl font-semibold tracking-tight text-surface-900 md:text-4xl">{title}</h2>
  {description && <p class="mt-3 text-base leading-relaxed text-surface-700">{description}</p>}
</header>
