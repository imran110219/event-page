---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | Ex Students of Jhikargacha Govt. M L Model High School"
  description="The page you are looking for does not exist."
>
  <main class="section-shell grid min-h-screen place-items-center py-20">
    <div class="max-w-xl text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-700">404 Error</p>
      <h1 class="mt-4 font-display text-4xl font-semibold text-surface-900">Page not found</h1>
      <p class="mt-3 text-surface-700">The link may be outdated or removed. Return to the homepage to explore upcoming events.</p>
      <a href="/" class="mt-7 inline-flex rounded-full bg-brand-700 px-6 py-3 text-sm font-semibold text-white transition hover:bg-brand-800">Go to Homepage</a>
    </div>
  </main>
</BaseLayout>
