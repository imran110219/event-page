---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import EventCard from '../components/EventCard.astro';
import Footer from '../components/Footer.astro';
import EmptyState from '../components/EmptyState.astro';
import { formatEventDate } from '../utils/date';
import { getUpcomingEvents } from '../utils/events';

const upcomingEvents = getUpcomingEvents();

const nextEventDate = upcomingEvents[0] ? formatEventDate(upcomingEvents[0].date) : 'TBD';
const totalCategories = new Set(upcomingEvents.map((event) => event.category)).size;
---

<BaseLayout
  title="Ex Students of Jhikargacha Govt. M L Model High School | Upcoming Events"
  description="Explore premium upcoming events from Ex Students of Jhikargacha Govt. M L Model High School including seminars, workshops, conferences, and community sessions."
>
  <Navbar />

  <main>
    <Hero
      totalUpcoming={upcomingEvents.length}
      nextEventDate={nextEventDate}
      totalCategories={totalCategories}
    />

    <section id="events" class="section-shell py-8 pb-20">
      <SectionHeader
        eyebrow="All Upcoming"
        title="Plan your next event"
        description="All upcoming events are sorted by nearest date. Browse, learn more, and register in seconds."
      />

      {upcomingEvents.length > 0 ? (
        <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {upcomingEvents.map((event) => (
            <EventCard event={event} />
          ))}
        </div>
      ) : (
        <div class="mt-8">
          <EmptyState
            title="No upcoming events have been published"
            description="We are currently finalizing the next schedule. Please check back shortly or contact us for updates."
          />
        </div>
      )}
    </section>

  </main>

  <Footer />
</BaseLayout>
