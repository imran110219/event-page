---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import type { EventItem } from '../../types/event';
import { getUpcomingEvents } from '../../utils/events';
import { formatEventDateLong } from '../../utils/date';

export const getStaticPaths = () =>
  getUpcomingEvents().map((event) => ({
    params: { slug: event.slug },
    props: { event }
  }));

interface Props {
  event: EventItem;
}

const { event } = Astro.props as Props;
---

<BaseLayout title={`${event.title} | Ex Students of Jhikargacha Govt. M L Model High School`} description={event.shortDescription} ogImage={event.coverImage}>
  <Navbar />

  <main class="pt-32">
    <section class="section-shell py-12">
      <a href="/#events" class="text-sm font-semibold text-brand-700 hover:text-brand-800">&larr; Back to all events</a>

      <article class="mt-6 overflow-hidden rounded-3xl border border-surface-200 bg-white shadow-soft" data-animate="reveal">
        <img src={event.coverImage} alt={event.title} class="h-72 w-full object-cover md:h-96" />

        <div class="grid gap-8 p-8 md:grid-cols-[1.35fr_1fr] md:p-10">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.15em] text-brand-700">{event.category}</p>
            <h1 class="mt-3 font-display text-3xl font-semibold tracking-tight text-surface-900 md:text-4xl">{event.title}</h1>
            <p class="mt-4 text-base leading-relaxed text-surface-700">{event.fullDescription}</p>

            <div class="mt-8 flex flex-wrap gap-3">
              <a
                href={event.registrationUrl}
                target="_blank"
                rel="noreferrer"
                class="rounded-full bg-brand-700 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-800"
              >
                Register Now
              </a>
              <a href="/#events" class="rounded-full border border-surface-300 px-5 py-2.5 text-sm font-semibold text-surface-800 transition hover:border-brand-700 hover:text-brand-700">Explore More Events</a>
            </div>
          </div>

          <aside class="rounded-2xl border border-surface-200 bg-surface-50 p-6">
            <h2 class="font-display text-xl font-semibold text-surface-900">Event Details</h2>
            <ul class="mt-4 space-y-3 text-sm text-surface-700">
              <li><span class="font-semibold text-surface-900">Date:</span> {formatEventDateLong(event.date)}</li>
              <li><span class="font-semibold text-surface-900">Time:</span> {event.time}</li>
              <li><span class="font-semibold text-surface-900">Location:</span> {event.location}</li>
              <li><span class="font-semibold text-surface-900">Category:</span> <span class="capitalize">{event.category}</span></li>
              {event.limitedSeats && <li><span class="font-semibold text-rose-600">Limited seats available</span></li>}
            </ul>
          </aside>
        </div>
      </article>
    </section>
  </main>

  <Footer />
</BaseLayout>
